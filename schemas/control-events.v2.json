{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smart-mirror.local/schemas/control-events.v2.json",
  "title": "Control Events v2",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "WIDGETS_SYNC",
        "WIDGETS_SYNC_APPLIED",
        "WIDGETS_SYNC_ERROR",
        "CAMERA_COUNTDOWN_STARTED",
        "CAMERA_COUNTDOWN_TICK",
        "CAMERA_CAPTURED",
        "CAMERA_ERROR",
        "WARDROBE_UPDATED"
      ]
    },
    "version": {
      "type": "integer",
      "const": 2
    },
    "sessionId": {
      "type": ["string", "null"]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object"
    }
  },
  "required": ["type", "version", "timestamp", "payload"]
}
