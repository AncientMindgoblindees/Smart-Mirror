{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smart-mirror.local/schemas/control-events.v2.json",
  "title": "Control Events v2",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "WIDGETS_SYNC",
        "WIDGETS_SYNC_APPLIED",
        "WIDGETS_SYNC_ERROR",
        "CAMERA_COUNTDOWN_STARTED",
        "CAMERA_COUNTDOWN_TICK",
        "CAMERA_CAPTURED",
        "CAMERA_ERROR",
        "WARDROBE_UPDATED",
        "DEVICE_PAIR",
        "DEVICE_SEARCHING",
        "DEVICE_CONNECTING",
        "DEVICE_CONNECTED",
        "DEVICE_DISCONNECTING",
        "DEVICE_DISCONNECTED",
        "DEVICE_ERROR"
      ]
    },
    "version": {
      "type": "integer",
      "const": 2
    },
    "sessionId": {
      "type": ["string", "null"]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object"
    }
  },
  "required": ["type", "version", "timestamp", "payload"],
  "oneOf": [
    {
      "if": {
        "properties": { "type": { "const": "DEVICE_SEARCHING" } }
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "properties": {
              "initiator": { "type": "string" }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": { "type": { "const": "DEVICE_CONNECTING" } }
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "properties": {
              "device_id": { "type": "string" },
              "display_name": { "type": ["string", "null"] }
            },
            "required": ["device_id"]
          }
        }
      }
    },
    {
      "if": {
        "properties": { "type": { "const": "DEVICE_CONNECTED" } }
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "properties": {
              "device_id": { "type": "string" },
              "display_name": { "type": ["string", "null"] }
            },
            "required": ["device_id"]
          }
        }
      }
    },
    {
      "if": {
        "properties": { "type": { "const": "DEVICE_DISCONNECTING" } }
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "properties": {
              "device_id": { "type": "string" },
              "reason": { "type": ["string", "null"] }
            },
            "required": ["device_id"]
          }
        }
      }
    },
    {
      "if": {
        "properties": { "type": { "const": "DEVICE_DISCONNECTED" } }
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "properties": {
              "device_id": { "type": "string" }
            },
            "required": ["device_id"]
          }
        }
      }
    },
    {
      "if": {
        "properties": { "type": { "const": "DEVICE_ERROR" } }
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "properties": {
              "device_id": { "type": ["string", "null"] },
              "message": { "type": "string" },
              "code": { "type": ["string", "null"] }
            },
            "required": ["message"]
          }
        }
      }
    }
  ]
}
