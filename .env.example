# WeatherAPI.com - https://www.weatherapi.com/docs/
# Do not commit real keys; copy this file to `.env` and fill in values.
WEATHERAPI_KEY=
WEATHERAPI_Q=San Francisco

# Google OAuth only.
# Register these redirect URIs in Google Cloud:
#   http://<PI_IP>:8002/api/oauth/google/callback
#   https://<your-public-host>/api/oauth/google/callback
GOOGLE_WEB_CLIENT_ID=
GOOGLE_WEB_CLIENT_SECRET=
GOOGLE_TV_CLIENT_ID=
GOOGLE_TV_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional override for the phone-facing OAuth QR URL.
# If blank, the backend will auto-detect the first Cloudflare tunnel hostname
# and prefer a `mirror.*` hostname when one exists.
OAUTH_PUBLIC_BASE_URL=
OAUTH_SUCCESS_REDIRECT_URL=https://smart-mirror.tech

# Mirror defaults and token encryption.
MIRROR_TOKEN_SECRET=
DEFAULT_MIRROR_HARDWARE_ID=
DEFAULT_MIRROR_FRIENDLY_NAME=

# Local backend behavior.
MIRROR_SYNC_INTERVAL_SEC=300

# Optional Cloudflare D1 sync for mirror/profile/widget/settings/clothing metadata
# and encrypted Google credential rows.
D1_WORKER_URL=
MIRROR_SYNC_TOKEN=
D1_SYNC_INTERVAL_SEC=600
D1_FORCE_FULL_SYNC=false

# Leonardo.Ai (optional; outfit try-on)
LEONARDO_API_KEY=
LEONARDO_MODEL_ID=
TRYON_LOCAL_KEEP_LAST=10

# Pi camera capture settings
PI_CAMERA_CAPTURE_WIDTH=1080
PI_CAMERA_CAPTURE_HEIGHT=1920
PI_CAMERA_MAX_DIM=1280
PI_CAMERA_PREVIEW_LORES_MAX=640
PI_CAMERA_JPEG_QUALITY=82
CAMERA_CAPTURE_BUTTON=UP
CAMERA_CAPTURE_COUNTDOWN_SEC=3
CAMERA_MIN_BOOT_BEFORE_COUNTDOWN_SEC=2.5
CAMERA_MJPEG_MAX_FPS=10
CAMERA_NATIVE_PREVIEW=0
CAMERA_NATIVE_COUNTDOWN_OVERLAY=1
