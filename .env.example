# WeatherAPI.com — https://www.weatherapi.com/docs/
# Sign up: https://www.weatherapi.com/signup.aspx
# Do not commit real keys; copy this file to `.env` and fill in values.
WEATHERAPI_KEY=
# Location query: city name, US zip, UK postcode, or "lat,lon"
WEATHERAPI_Q=San Francisco

# OAuth — Google & Microsoft (step-by-step: docs/oauth-google-microsoft-setup.md)
# You must register apps in YOUR Google Cloud and Azure portals; we cannot do that from the repo.
# Redirect examples (use your real host/IP and port):
#   http://<PI_IP>:8002/api/oauth/google/callback
#   http://<PI_IP>:8002/api/oauth/microsoft/callback
# Google supports split credentials by flow:
#   - Web redirect flow (companion app direct sign-in)
#   - Device/TV flow (mirror QR + code)
#
# Preferred split config:
GOOGLE_WEB_CLIENT_ID=
GOOGLE_WEB_CLIENT_SECRET=
GOOGLE_TV_CLIENT_ID=
GOOGLE_TV_CLIENT_SECRET=
#
# Backward-compatible single-pair fallback (used if split vars are empty):
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Token encryption key (auto-generated on first run if empty)
MIRROR_TOKEN_SECRET=

# Calendar sync interval in seconds (default 300 = 5 minutes)
MIRROR_SYNC_INTERVAL_SEC=300

# Cloudflare D1 sync (optional — leave both blank to disable)
# Worker base URL only (no path): https://smart-mirror-d1-sync.<your-subdomain>.workers.dev
# Deploy: deploy/worker — set secret: wrangler secret put MIRROR_SYNC_TOKEN (same value as below)
D1_WORKER_URL=
MIRROR_SYNC_TOKEN=
D1_SYNC_INTERVAL_SEC=600
# One-shot recovery: set to true once to reset D1 pull cursors and re-sync all rows from D1, then remove.
D1_FORCE_FULL_SYNC=false

# Leonardo.Ai — https://docs.leonardo.ai/docs/getting-started (optional; outfit try-on)
LEONARDO_API_KEY=
# Platform model UUID from Leonardo app (defaults to a stock SD model if unset)
LEONARDO_MODEL_ID=
# Keep local generated try-ons on Pi (newest N files retained).
TRYON_LOCAL_KEEP_LAST=10

# Pi camera capture settings
# Portrait defaults for mirror-style framing.
PI_CAMERA_CAPTURE_WIDTH=1080
PI_CAMERA_CAPTURE_HEIGHT=1920
# Max long-edge size for latest person photo saved for try-on preview (0 disables resize)
PI_CAMERA_MAX_DIM=1280
# Long-edge cap for Picamera2 lores frames used only for /api/camera/live (MJPEG) live view
PI_CAMERA_PREVIEW_LORES_MAX=640
# JPEG quality for latest person photo transport optimization (20-95)
PI_CAMERA_JPEG_QUALITY=82
# GPIO button id used for physical capture trigger: LAYOUT | UP | DOWN | DISPLAY
CAMERA_CAPTURE_BUTTON=UP
CAMERA_CAPTURE_COUNTDOWN_SEC=3
# Seconds (min) from capture start before countdown; keeps UI boot + live preview aligned with server ticks.
CAMERA_MIN_BOOT_BEFORE_COUNTDOWN_SEC=2.5
# MJPEG /api/camera/live max frame rate (lower if Pi CPU spikes).
CAMERA_MJPEG_MAX_FPS=10
# Native preview mode: launches fullscreen rpicam-hello during capture flow
# for smoother camera preview (mirror UI overlays controls/countdown only).
CAMERA_NATIVE_PREVIEW=0
# Native countdown overlay window (OS-level) shown on top of native preview.
CAMERA_NATIVE_COUNTDOWN_OVERLAY=1
# Pi diagnostics: curl -s http://127.0.0.1:8002/api/health/d1 | python3 -m json.tool
